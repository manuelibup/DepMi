generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════════════════════
// ENUMS
// ═══════════════════════════════════════════════════════════════════════════════

enum AuthProvider {
  EMAIL // Email + password (bcrypt hashed)
  GOOGLE // Google OAuth
  WHATSAPP // WhatsApp phone verification
}

enum OtpType {
  PHONE_VERIFICATION
  EMAIL_RESET
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

enum DepTier {
  SEEDLING // 0–50 Deps
  RISING // 51–200 Deps
  TRUSTED // 201–500 Deps
  ELITE // 501–1000 Deps
  LEGEND // 1000+ Deps
}

// KYC tiers — each tier unlocks platform features
// Store creation requires TIER_2 (BVN verified) minimum
enum KycTier {
  UNVERIFIED // No KYC — can browse and create demands
  TIER_0 // Social accounts linked — can bid (limited)
  TIER_1 // NIN verified — can buy via escrow
  TIER_2 // BVN verified — can CREATE A STORE, sell, receive payouts
  TIER_3 // Proof of address — full access, higher transaction limits
  BUSINESS // CAC + TIN verified — business account, highest limits
}

enum OrderStatus {
  PENDING_PAYMENT
  PAYMENT_ESCROWED
  OUT_FOR_DELIVERY
  DELIVERED
  DISPUTED
  REFUNDED
  FUNDS_RELEASED
}

enum Category {
  FASHION
  GADGETS
  BEAUTY
  FOOD
  FURNITURE
  VEHICLES
  SERVICES
  OTHER
}

enum NotificationType {
  BID_RECEIVED // Store owner: "A vendor bid on your demand"
  BID_ACCEPTED // Bidder: "Your bid was accepted"
  ORDER_PLACED // Store owner: "New order received"
  ORDER_ESCROWED // Both: "Payment secured in escrow"
  ORDER_SHIPPED // Buyer: "Your order has been shipped"
  ORDER_DELIVERED // Both: "Order marked as delivered"
  ORDER_DISPUTED // Both: "A dispute has been raised"
  FUNDS_RELEASED // Store owner: "Funds released to your account"
  DEP_EARNED // Both: "You earned a Dep!"
  SYSTEM // Generic system notifications
}

// ═══════════════════════════════════════════════════════════════════════════════
// USER — Personal identity, auth, buying, trust
// ═══════════════════════════════════════════════════════════════════════════════

model User {
  id String @id @default(uuid())

  // Profile
  username    String?   @unique
  displayName String
  dateOfBirth DateTime? // Used for age gating
  email         String?   @unique
  phoneNumber   String?   @unique
  phoneVerified Boolean   @default(false)
  avatarUrl     String?

  // Auth — supports multiple providers per user
  // e.g. sign up with email, later link Google
  accounts Account[]

  // Trust score (as a buyer — stores have their own seller trust)
  depCount Int     @default(0) // Atomic counter, incremented with DepTransaction
  depTier  DepTier @default(SEEDLING)

  // KYC — determines what the user can do
  // UNVERIFIED → browse/demand | TIER_1 → buy | TIER_2 → CREATE STORES + sell
  kycTier   KycTier    @default(UNVERIFIED)
  kycStatus KycStatus?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations — personal account
  stores          Store[]          @relation("UserStores") // Like Facebook Pages — 0, 1, or many
  demands         Demand[]         @relation("UserDemands")
  ordersAsBuyer   Order[]          @relation("BuyerOrders")
  depTransactions DepTransaction[] @relation("UserDepTransactions")
  notifications   Notification[]   @relation("UserNotifications")
  otpTokens       OtpToken[]
  storeInvite     StoreInvite?
}

// ═══════════════════════════════════════════════════════════════════════════════
// AUTH — Flexible multi-provider auth (email/password, Google, WhatsApp)
// ═══════════════════════════════════════════════════════════════════════════════

model Account {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  provider   AuthProvider
  providerId String? // Google subject ID, WhatsApp phone ID — null for EMAIL

  // Email/password auth only
  // Password MUST be hashed with bcrypt (12+ salt rounds) in app layer
  // NEVER store plaintext passwords
  passwordHash String?

  createdAt DateTime @default(now())

  @@unique([provider, providerId]) // Can't have two accounts with same provider + ID
  @@index([userId])
}

// ═══════════════════════════════════════════════════════════════════════════════
// KYC — Detailed verification records (Smile ID / Dojah reference tokens only)
// When a verification step completes, update this record AND bump User.kycTier
// ═══════════════════════════════════════════════════════════════════════════════

model KycStatus {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  // Each step stores the verification provider's reference token
  socialVerified Boolean @default(false) // → bumps to TIER_0 (Phone OTP)
  ninRef         String? // → bumps to TIER_1 (can buy)
  bvnRef         String? // → bumps to TIER_2 (can create stores + sell)
  proofOfAddress Boolean @default(false) // → bumps to TIER_3
  cacNumber      String? // → bumps to BUSINESS (with tinNumber)
  tinNumber      String? // → bumps to BUSINESS (with cacNumber)

  updatedAt DateTime @updatedAt
}

// ═══════════════════════════════════════════════════════════════════════════════
// STORE — Business identity (like a Facebook Page)
// A User can own multiple Stores (e.g. one for fashion, one for gadgets)
// ⚠️ APP LOGIC: User.kycTier must be >= TIER_2 to create a Store
// ═══════════════════════════════════════════════════════════════════════════════

model Store {
  id      String @id @default(uuid())
  ownerId String // The personal account that owns this store
  owner   User   @relation("UserStores", fields: [ownerId], references: [id])

  // Public storefront info
  name        String  @unique // Appears in /store/[slug]
  slug        String  @unique // URL-safe version of name
  description String?
  bannerUrl   String?
  logoUrl     String?
  location    String? // Primary business location

  // Trust score (as a seller — separate from owner's buyer trust)
  depCount Int     @default(0)
  depTier  DepTier @default(SEEDLING)

  // Paystack split payment subaccount (for auto-settlement)
  paystackSubcode String?

  isActive Boolean @default(true)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  products        Product[]        @relation("StoreProducts")
  bids            Bid[]            @relation("StoreBids")
  ordersAsSeller  Order[]          @relation("SellerOrders")
  depTransactions DepTransaction[] @relation("StoreDepTransactions")

  @@index([ownerId])
  @@index([slug])
}

// ═══════════════════════════════════════════════════════════════════════════════
// TRUST SYSTEM — Audit trail for Deps
// ═══════════════════════════════════════════════════════════════════════════════

// Source of truth for trust scores
// App logic: create DepTransaction + atomically increment User.depCount or Store.depCount
model DepTransaction {
  id String @id @default(uuid())

  // Either userId OR storeId is set — deps for buying vs selling
  userId  String?
  user    User?   @relation("UserDepTransactions", fields: [userId], references: [id])
  storeId String?
  store   Store?  @relation("StoreDepTransactions", fields: [storeId], references: [id])

  amount  Int // +1 completed purchase (user) / +1 completed sale (store)
  reason  String // "Order #xyz completed"
  orderId String? // Link to the order that triggered this dep

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([storeId])
}

// ═══════════════════════════════════════════════════════════════════════════════
// DEMAND ENGINE — Buyer requests + Vendor bids
// ═══════════════════════════════════════════════════════════════════════════════

model Demand {
  id     String @id @default(uuid())
  userId String
  user   User   @relation("UserDemands", fields: [userId], references: [id])

  text     String
  budget   Decimal  @db.Decimal(10, 2)
  category Category @default(OTHER)
  location String?

  closesAt DateTime?
  isActive Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  bids   Bid[]
  orders Order[] @relation("DemandOrders")

  @@index([isActive, category])
  @@index([userId])
}

model Bid {
  id       String @id @default(uuid())
  demandId String
  demand   Demand @relation(fields: [demandId], references: [id])

  storeId String
  store   Store  @relation("StoreBids", fields: [storeId], references: [id])

  amount    Decimal  @db.Decimal(10, 2)
  proposal  String?
  productId String?
  product   Product? @relation("BidProduct", fields: [productId], references: [id])

  isAccepted Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  order Order? @relation("BidOrder")

  @@index([demandId])
  @@index([storeId])
}

// ═══════════════════════════════════════════════════════════════════════════════
// PRODUCT CATALOG
// ═══════════════════════════════════════════════════════════════════════════════

model Product {
  id      String @id @default(uuid())
  storeId String
  store   Store  @relation("StoreProducts", fields: [storeId], references: [id])

  title       String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  category    Category @default(OTHER)

  viewCount Int     @default(0)
  inStock   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  images     ProductImage[]
  orderItems OrderItem[]
  bids       Bid[]          @relation("BidProduct")

  @@index([category, inStock])
  @@index([storeId])
}

model ProductImage {
  id        String  @id @default(uuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  url   String
  order Int    @default(0)

  @@index([productId])
}

// ═══════════════════════════════════════════════════════════════════════════════
// ORDERS & ESCROW
// ═══════════════════════════════════════════════════════════════════════════════

model Order {
  id      String @id @default(uuid())
  buyerId String
  buyer   User   @relation("BuyerOrders", fields: [buyerId], references: [id])

  sellerId String
  seller   Store  @relation("SellerOrders", fields: [sellerId], references: [id])

  totalAmount Decimal     @db.Decimal(10, 2)
  status      OrderStatus @default(PENDING_PAYMENT)

  // Origin tracking
  demandId String?
  demand   Demand? @relation("DemandOrders", fields: [demandId], references: [id])
  bidId    String? @unique
  bid      Bid?    @relation("BidOrder", fields: [bidId], references: [id])

  // Escrow / Paystack
  paystackRef String? @unique
  isEscrowed  Boolean @default(true)

  // Delivery
  deliveryAddress String?
  deliveryNote    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  items OrderItem[]

  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
}

model OrderItem {
  id      String @id @default(uuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  quantity Int     @default(1)
  price    Decimal @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
}

// ═══════════════════════════════════════════════════════════════════════════════
// NOTIFICATIONS
// ═══════════════════════════════════════════════════════════════════════════════

model Notification {
  id     String @id @default(uuid())
  userId String
  user   User   @relation("UserNotifications", fields: [userId], references: [id])

  type   NotificationType
  title  String
  body   String
  link   String?
  isRead Boolean          @default(false)

  createdAt DateTime @default(now())

  @@index([userId, isRead])
}

// ═══════════════════════════════════════════════════════════════════════════════
// NEW: VENDOR INVITE & OTP SYSTEM
// ═══════════════════════════════════════════════════════════════════════════════

model OtpToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      OtpType  @default(PHONE_VERIFICATION)
  codeHash  String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  
  @@index([userId])
}

model StoreInvite {
  id        String       @id @default(uuid())
  email     String
  expiresAt DateTime
  status    InviteStatus @default(PENDING)
  userId    String?      @unique
  user      User?        @relation(fields: [userId], references: [id])
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  
  @@index([email])
}

// ═══════════════════════════════════════════════════════════════════════════════
// WAITLIST
// ═══════════════════════════════════════════════════════════════════════════════

model Waitlist {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now())
}
