generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String           @id @default(uuid())
  email           String?          @unique
  phoneNumber     String?          @unique
  depTier         DepTier          @default(SEEDLING)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  avatarUrl       String?
  dateOfBirth     DateTime?
  depCount        Int              @default(0)
  displayName     String
  kycTier         KycTier          @default(UNVERIFIED)
  phoneVerified   Boolean          @default(false)
  emailVerified   Boolean          @default(false)
  username        String?          @unique
  cumulativeSpend Int              @default(0)
  address         String?
  city            String?
  state           String?
  country         String?
  bio             String?
  coverUrl        String?
  adminRole       AdminRole?
  totpEnabled     Boolean          @default(false)
  totpSecret      String?
  adminPinHash    String?
  lastActiveAt    DateTime?
  isBanned           Boolean          @default(false)
  onboardingComplete        Boolean          @default(false)
  interests                 String[]
  notifDemandCategories     String[]
  accounts           Account[]
  comments        Comment[]        @relation("UserComments")
  demands         Demand[]         @relation("UserDemands")
  depTransactions DepTransaction[] @relation("UserDepTransactions")
  kycStatus       KycStatus?
  messagesSent    Message[]
  notifications   Notification[]   @relation("UserNotifications")
  ordersAsBuyer   Order[]          @relation("BuyerOrders")
  otpTokens       OtpToken[]
  productLikes    ProductLike[]
  demandLikes     DemandLike[]
  productWatches  ProductWatch[]
  reviewsLeft     Review[]         @relation("BuyerReviews")
  savedProducts   SavedProduct[]
  savedDemands    SavedDemand[]
  stores          Store[]          @relation("UserStores")
  storeFollows    StoreFollow[]    @relation("UserStoreFollows")
  followers       UserFollow[]     @relation("UserFollowing")
  following       UserFollow[]     @relation("UserFollowers")
  productViews    ProductView[]
  demandViews     DemandView[]
  storeInvite     StoreInvite?
  conversations   Conversation[]   @relation("ConversationParticipants")
  posts           Post[]           @relation("AuthoredPosts")
  postLikes       PostLike[]       @relation("PostLikes")
  postComments    PostComment[]    @relation("PostComments")
  referralCode    ReferralCode?
  referralsMade   ReferralTransaction[] @relation("ReferrerTxns")
  referralReceived ReferralTransaction[] @relation("ReferredTxns")
  pushSubscriptions PushSubscription[]
  events            Event[]

  analyticsOptOut   Boolean          @default(false)
  strikeCount       Int              @default(0)
  strikes           Strike[]

  @@index([lastActiveAt])
}

model Strike {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reason    String
  context   String?
  createdAt DateTime @default(now())

  @@index([userId])
}

model Account {
  id           String       @id @default(uuid())
  userId       String
  provider     AuthProvider
  providerId   String?
  passwordHash String?
  createdAt    DateTime     @default(now())
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@index([userId])
}

model KycStatus {
  id             String   @id @default(uuid())
  userId         String   @unique
  socialVerified Boolean  @default(false)
  ninRef         String?  @unique
  bvnRef         String?  @unique
  proofOfAddress Boolean  @default(false)
  cacNumber      String?  @unique
  tinNumber      String?
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id])
}

// ─── Store News Feed ────────────────────────────────────────────────────────

model Post {
  id           String        @id @default(uuid())
  storeId      String
  authorId     String
  body         String
  type         PostType      @default(POST)
  likeCount    Int           @default(0)
  commentCount Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  store        Store         @relation("StorePosts", fields: [storeId], references: [id], onDelete: Cascade)
  author       User          @relation("AuthoredPosts", fields: [authorId], references: [id])
  images       PostImage[]
  likes        PostLike[]
  comments     PostComment[]

  @@index([storeId, createdAt(sort: Desc)])
  @@index([authorId])
}

model PostImage {
  id     String @id @default(uuid())
  postId String
  url    String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
}

model PostLike {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation("PostLikes", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model PostComment {
  id        String   @id @default(uuid())
  postId    String
  authorId  String
  text      String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    User     @relation("PostComments", fields: [authorId], references: [id])

  @@index([postId])
}

enum PostType {
  POST
  ANNOUNCEMENT
}

// ────────────────────────────────────────────────────────────────────────────

model Store {
  id                  String                  @id @default(uuid())
  ownerId             String
  name                String                  @unique
  slug                String                  @unique
  description         String?
  bannerUrl           String?
  logoUrl             String?
  location            String?
  depCount            Int                     @default(0)
  depTier             DepTier                 @default(SEEDLING)
  paystackSubcode     String?
  isActive            Boolean                 @default(true)
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  rating              Float                   @default(0)
  reviewCount         Int                     @default(0)
  subscriptionEndsAt  DateTime?
  tier                StoreTier               @default(TRIAL)
  trialEndsAt         DateTime?
  bankAccountName     String?
  bankAccountNo       String?
  bankCode            String?
  cryptoWalletAddr      String?
  cryptoPaymentsEnabled Boolean               @default(false)
  preferredPayoutRail   PaymentRail           @default(NAIRA)
  cacDocUrl           String?
  rcNumber            String?
  tin                 String?
  verificationStatus    StoreVerificationStatus @default(UNVERIFIED)
  feeWaiverUntil        DateTime?
  storeState            String?
  localDeliveryFee      Decimal?                @db.Decimal(10, 2)
  nationwideDeliveryFee Decimal?                @db.Decimal(10, 2)
  dispatchEnabled       Boolean                 @default(true)
  pickupAddress         String?
  shipbubbleAddrCode    Int?
  bids                Bid[]                   @relation("StoreBids")
  depTransactions     DepTransaction[]        @relation("StoreDepTransactions")
  ordersAsSeller      Order[]                 @relation("SellerOrders")
  products            Product[]               @relation("StoreProducts")
  reviews             Review[]                @relation("StoreReviews")
  posts               Post[]                  @relation("StorePosts")
  owner               User                    @relation("UserStores", fields: [ownerId], references: [id])
  followers           StoreFollow[]           @relation("StoreFollowers")

  @@index([ownerId])
  @@index([slug])
}

model DepTransaction {
  id        String   @id @default(uuid())
  userId    String?
  amount    Int
  reason    String
  orderId   String?
  createdAt DateTime @default(now())
  storeId   String?
  store     Store?   @relation("StoreDepTransactions", fields: [storeId], references: [id])
  user      User?    @relation("UserDepTransactions", fields: [userId], references: [id])

  @@index([userId])
  @@index([storeId])
}

model Demand {
  id         String        @id @default(uuid())
  userId     String
  text       String
  slug       String?       @unique
  budget     Decimal       @db.Decimal(10, 2)
  budgetMin  Decimal?      @db.Decimal(10, 2)
  category      Category      @default(OTHER)
  categoryOther String?
  location      String?
  closesAt      DateTime?
  isActive   Boolean       @default(true)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  currency   String        @default("₦")
  videoUrl   String?
  viewCount  Int           @default(0)
  images     DemandMedia[]
  bids       Bid[]
  comments   Comment[]     @relation("DemandComments")
  likes      DemandLike[]
  saves      SavedDemand[]
  views      DemandView[]
  user       User          @relation("UserDemands", fields: [userId], references: [id])
  orders     Order[]       @relation("DemandOrders")

  @@index([isActive, category])
  @@index([userId])
  @@index([slug])
}

model DemandLike {
  id        String   @id @default(uuid())
  userId    String
  demandId  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  demand    Demand   @relation(fields: [demandId], references: [id], onDelete: Cascade)

  @@unique([userId, demandId])
  @@index([demandId])
  @@index([userId])
}

model SavedDemand {
  id        String   @id @default(uuid())
  userId    String
  demandId  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  demand    Demand   @relation(fields: [demandId], references: [id], onDelete: Cascade)

  @@unique([userId, demandId])
  @@index([demandId])
  @@index([userId])
}

model DemandMedia {
  id       String @id @default(uuid())
  demandId String
  url      String
  order    Int    @default(0)
  demand   Demand @relation(fields: [demandId], references: [id], onDelete: Cascade)

  @@index([demandId])
}

model Bid {
  id         String   @id @default(uuid())
  demandId   String
  amount     Decimal  @db.Decimal(10, 2)
  proposal   String?
  isAccepted Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  productId  String?
  storeId    String
  demand     Demand   @relation(fields: [demandId], references: [id])
  product    Product? @relation("BidProduct", fields: [productId], references: [id])
  store      Store     @relation("StoreBids", fields: [storeId], references: [id])
  order      Order?    @relation("BidOrder")
  replies    Comment[] @relation("BidReplies")

  @@index([demandId])
  @@index([storeId])
}

model Product {
  id              String         @id @default(uuid())
  storeId         String
  title           String
  description     String?
  price           Decimal        @db.Decimal(10, 2)
  category        Category       @default(OTHER)
  categoryOther   String?
  viewCount       Int            @default(0)
  inStock         Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  videoUrl        String?
  isPortfolioItem Boolean        @default(false)
  isDigital       Boolean        @default(false)
  fileUrl         String?
  slug            String?        @unique
  currency        String         @default("₦")
  isFeatured      Boolean        @default(false)
  deliveryFee     Decimal        @default(2500) @db.Decimal(10, 2)
  stock           Int            @default(1)
  bids            Bid[]          @relation("BidProduct")
  comments        Comment[]      @relation("ProductComments")
  orderItems      OrderItem[]
  reviews         Review[]       @relation("ProductReviews")
  likes           ProductLike[]
  saves           SavedProduct[]
  views           ProductView[]
  store           Store          @relation("StoreProducts", fields: [storeId], references: [id])
  images          ProductImage[]
  productWatches  ProductWatch[]

  @@index([category, inStock])
  @@index([storeId])
}

model ProductImage {
  id        String  @id @default(uuid())
  productId String
  url       String
  order     Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Order {
  id                String       @id @default(uuid())
  buyerId           String
  sellerId          String
  totalAmount       Decimal      @db.Decimal(10, 2)
  status            OrderStatus  @default(PENDING)
  paystackRef       String?      @unique
  deliveryAddress   String?
  deliveryNote      String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  bidId             String?      @unique
  demandId          String?
  escrowStatus      EscrowStatus @default(HELD)
  cryptoAmountUsdc  Decimal?     @db.Decimal(18, 6)
  cryptoTxHash      String?
  paymentRail       PaymentRail  @default(NAIRA)
  platformFeeNgn    Decimal?     @db.Decimal(10, 2)
  virtualAcctBank   String?
  virtualAcctExpiry DateTime?
  virtualAcctNo     String?
  deliveryMethod    String       @default("DELIVERY")
  trackingNo        String?
  dispatchOrderId   String?
  dispatchProvider  String?
  shipbubbleReqToken String?
  isDigital         Boolean      @default(false)
  bid               Bid?         @relation("BidOrder", fields: [bidId], references: [id])
  buyer             User         @relation("BuyerOrders", fields: [buyerId], references: [id])
  demand            Demand?      @relation("DemandOrders", fields: [demandId], references: [id])
  seller            Store        @relation("SellerOrders", fields: [sellerId], references: [id])
  items             OrderItem[]
  payment           Payment?
  review            Review?

  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
}

model Payment {
  id                   String    @id @default(uuid())
  orderId              String    @unique
  virtualAccountNumber String?
  bankName             String?
  accountName          String?
  expiresAt            DateTime?
  paystackReference    String?   @unique
  amount               Decimal   @db.Decimal(10, 2)
  currency             String    @default("NGN")
  paid                 Boolean   @default(false)
  paidAt               DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  order                Order     @relation(fields: [orderId], references: [id])
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  productId String
  quantity  Int      @default(1)
  price     Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  order     Order    @relation(fields: [orderId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])

  @@index([orderId])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  link      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation("UserNotifications", fields: [userId], references: [id])

  @@index([userId, isRead])
}

model OtpToken {
  id        String   @id @default(uuid())
  userId    String
  type      OtpType  @default(PHONE_VERIFICATION)
  codeHash  String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model StoreInvite {
  id        String       @id @default(uuid())
  email     String
  expiresAt DateTime
  status    InviteStatus @default(PENDING)
  userId    String?      @unique
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  user      User?        @relation(fields: [userId], references: [id])

  @@index([email])
}

model Waitlist {
  id                 String    @id @default(uuid())
  email              String    @unique
  createdAt          DateTime  @default(now())
  launchEmailSentAt  DateTime?
}

// ─── Referral System ─────────────────────────────────────────────────────────

model ReferralConfig {
  id               String   @id @default("singleton")
  globalEnabled    Boolean  @default(false)
  rewardPercentage Float    @default(5.0)
  durationDays     Int      @default(30)
  updatedAt        DateTime @updatedAt
}

model ReferralCode {
  id             String                @id @default(uuid())
  userId         String                @unique
  code           String                @unique
  perUserEnabled Boolean               @default(true)
  createdAt      DateTime              @default(now())
  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  referrals      ReferralTransaction[] @relation("ByCode")
}

model ReferralTransaction {
  id             String         @id @default(uuid())
  referralCodeId String
  referrerId     String
  referredUserId String
  orderId        String?
  rewardAmount   Decimal        @db.Decimal(10, 2)
  status         ReferralStatus @default(PENDING)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  referralCode   ReferralCode   @relation("ByCode", fields: [referralCodeId], references: [id])
  referrer       User           @relation("ReferrerTxns", fields: [referrerId], references: [id])
  referred       User           @relation("ReferredTxns", fields: [referredUserId], references: [id])

  @@index([referrerId])
  @@index([referredUserId])
  @@index([status])
}

model ProductLike {
  id        String   @id @default(uuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId])
  @@index([userId])
}

model SavedProduct {
  id        String   @id @default(uuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId])
  @@index([userId])
}

model ProductWatch {
  id          String   @id @default(uuid())
  userId      String
  searchQuery String?
  productId   String?
  notified    Boolean  @default(false)
  createdAt   DateTime @default(now())
  product     Product? @relation(fields: [productId], references: [id])
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([productId])
}

model Review {
  id        String   @id @default(uuid())
  orderId   String   @unique
  buyerId   String
  storeId   String
  productId String?
  rating    Int
  text      String?
  createdAt DateTime @default(now())
  buyer     User     @relation("BuyerReviews", fields: [buyerId], references: [id])
  order     Order    @relation(fields: [orderId], references: [id])
  store     Store    @relation("StoreReviews", fields: [storeId], references: [id])
  product   Product? @relation("ProductReviews", fields: [productId], references: [id])

  @@index([buyerId])
  @@index([storeId])
  @@index([productId])
}

model Comment {
  id        String   @id @default(uuid())
  text      String
  authorId  String
  productId String?
  demandId  String?
  bidId     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  author    User     @relation("UserComments", fields: [authorId], references: [id])
  demand    Demand?  @relation("DemandComments", fields: [demandId], references: [id], onDelete: Cascade)
  product   Product? @relation("ProductComments", fields: [productId], references: [id], onDelete: Cascade)
  bid       Bid?     @relation("BidReplies", fields: [bidId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([demandId])
  @@index([authorId])
  @@index([bidId])
}

model StoreFollow {
  id        String   @id @default(uuid())
  userId    String
  storeId   String
  notify    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  store     Store    @relation("StoreFollowers", fields: [storeId], references: [id], onDelete: Cascade)
  user      User     @relation("UserStoreFollows", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, storeId])
  @@index([storeId, notify])
  @@index([userId])
}

model UserFollow {
  id          String   @id @default(uuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("UserFollowers", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("UserFollowing", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Conversation {
  id                 String    @id @default(uuid())
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  lastMessageAt      DateTime  @default(now())
  lastMessagePreview String?
  messages           Message[]
  participants       User[]    @relation("ConversationParticipants")
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  senderId       String
  text           String?
  read           Boolean      @default(false)
  createdAt      DateTime     @default(now())
  mediaUrl       String?
  type           MessageType  @default(TEXT)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId, read])
}

enum AuthProvider {
  EMAIL
  GOOGLE
  WHATSAPP
}

enum OtpType {
  PHONE_VERIFICATION
  EMAIL_RESET
  EMAIL_VERIFICATION
  TRANSACTIONAL
  ACCOUNT_UPDATE
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

enum DepTier {
  SEEDLING
  RISING
  TRUSTED
  ELITE
  LEGEND
}

enum StoreTier {
  TRIAL
  FREE
  BASIC
  PRO
}

enum KycTier {
  UNVERIFIED
  TIER_0
  TIER_1
  TIER_2
  TIER_3
  BUSINESS
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  COMPLETED
  CANCELLED
  DISPUTED
  RESOLVED_BUYER
  RESOLVED_VENDOR
  REFUNDED
}

enum EscrowStatus {
  HELD
  RELEASING
  RELEASED
}

enum PaymentRail {
  NAIRA
  CRYPTO
}

enum StoreVerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum Category {
  FASHION
  GADGETS
  BEAUTY
  COSMETICS
  FOOD
  FURNITURE
  VEHICLES
  SERVICES
  TRANSPORT
  SPORT
  HOUSING
  BOOKS
  COURSE
  OTHER
}

enum NotificationType {
  BID_RECEIVED
  BID_ACCEPTED
  ORDER_PLACED
  ORDER_CONFIRMED
  ORDER_SHIPPED
  ORDER_DELIVERED
  PAYMENT_RELEASED
  DISPUTE_OPENED
  DISPUTE_RESOLVED
  PRODUCT_AVAILABLE
  DEP_EARNED
  SYSTEM
  COMMENT_RECEIVED
  MENTION
  NEW_PRODUCT_FROM_STORE
  NEW_DEMAND
  ANNOUNCEMENT
  SOCIAL_ACTIVITY  // "Your friend X just bought Y from Z" — social proof feed
  STORE_FOLLOW_SALE // "A store you follow just completed a sale" — seller social proof
}

enum MessageType {
  TEXT
  IMAGE
  AUDIO
  STICKER
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  MODERATOR
}

enum ReferralStatus {
  PENDING
  QUALIFIED
  PAID
  FAILED
}
model ProductView {
  id         String   @id @default(uuid())
  productId  String
  userId     String?
  identifier String // IP hash or similar
  createdAt  DateTime @default(now())
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([identifier])
  @@index([createdAt])
}

model DemandView {
  id         String   @id @default(uuid())
  demandId   String
  userId     String?
  identifier String // IP hash or similar
  createdAt  DateTime @default(now())
  demand     Demand   @relation(fields: [demandId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([demandId])
  @@index([identifier])
  @@index([createdAt])
}

// ─── Behavioral Analytics ──────────────────────────────────────────────────

model Event {
  id         String    @id @default(cuid())
  type       EventType
  userId     String?
  sessionId  String    // anonymous UUID from localStorage
  targetId   String?   // productId | demandId | storeId | etc.
  targetType String?   // "product" | "demand" | "store" | "search"
  metadata   Json?     // feed position, search query, device type, etc.
  createdAt  DateTime  @default(now())
  user       User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([type, createdAt])
  @@index([targetId, type])
  @@index([sessionId])
  @@index([createdAt])
}

model DailyEventSummary {
  id          String    @id @default(cuid())
  date        DateTime  @db.Date
  type        EventType
  targetId    String?
  targetType  String?
  count       Int       @default(0)
  uniqueUsers Int       @default(0)

  @@unique([date, type, targetId])
  @@index([date])
  @@index([targetId, type])
}

enum EventType {
  FEED_IMPRESSION  // user scrolled past item (Intersection Observer)
  PRODUCT_VIEW     // opened product detail
  DEMAND_VIEW      // opened demand detail
  STORE_VIEW       // opened store page
  SEARCH           // submitted a search query
  LIKE             // liked a product or demand
  SAVE             // saved a product
  BID              // placed a bid
  ORDER            // placed an order
  SHARE            // tapped share
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
