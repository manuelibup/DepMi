# Normalize line endings to LF on commit, checkout as LF everywhere
* text=auto eol=lf

# Force binary files to not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.svg text eol=lf
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
*.docx binary
*.thmx binary
